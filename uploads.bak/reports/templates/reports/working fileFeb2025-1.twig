<table class="table table-striped" cellspacing="0" cellpadding="3" nobr="true" style="font-size: 9px;">
    {# 🔹 Table Header Row: Cycle Names & Subjects #}
    <tr>
        <td class="header bg-primary border-top border-bottom border-left border-right">
            {{ __('Subjects') }}
        </td>
        <td class="header bg-primary border-top border-bottom border-left border-right text-center">
            Marksheet 1 - Grade
        </td>
        <td class="header bg-primary border-top border-bottom border-left border-right text-center">
            Marksheet 1 - Effort
        </td>
        <td class="header bg-primary border-top border-bottom border-left border-right text-center">
            Marksheet 2 (December Exam) - Grade
        </td>
        <td class="header bg-primary border-top border-bottom border-left border-right text-center">
            Marksheet 2 (December Exam) - Effort
        </td>
    </tr>

    {# 🔹 Iterate Through Each Course and Display Data for All Cycles #}
    {% for course, assessments in internalAssessmentByCourse.courses %}
    <tr>
        <td class="border-top border-bottom border-left" style="font-weight: bold;">
            {{ course }}
        </td>

        {# ✅ Retrieve "Marksheet 1 -October 2025" Data #}
        {% set marksheet1 = assessments["Marksheet 1 -October 2025"] is defined ? assessments["Marksheet 1 -October 2025"] : {} %}
        
        {# ✅ Retrieve "December Exam" Data for Marksheet 2 #}
        {% set marksheet2 = assessments["December Exam"] is defined ? assessments["December Exam"] : {} %}

        {# ✅ Display Grade for Marksheet 1 #}
        <td class="border-top border-bottom border-left text-center">
            {{ marksheet1.attainmentValue is defined and marksheet1.attainmentValue is not empty
                ? marksheet1.attainmentValue
                : 'N/A' }}
        </td>

        {# ✅ Display Effort for Marksheet 1 (Using Effort Value Instead of Descriptor) #}
        <td class="border-top border-bottom border-left border-right text-center" style="font-size: 8px;">
            {{ marksheet1.effortValue is defined and marksheet1.effortValue is not empty
                ? marksheet1.effortValue
                : 'N/A' }}
        </td>

        {# ✅ Display Grade for Marksheet 2 (December Exam) #}
        <td class="border-top border-bottom border-left text-center">
            {{ marksheet2.attainmentValue is defined and marksheet2.attainmentValue is not empty
                ? marksheet2.attainmentValue
                : 'N/A' }}
        </td>

        {# ✅ Display Effort for Marksheet 2 (Using Effort Value Instead of Descriptor) #}
        <td class="border-top border-bottom border-left border-right text-center" style="font-size: 8px;">
            {{ marksheet2.effortValue is defined and marksheet2.effortValue is not empty
                ? marksheet2.effortValue
                : 'N/A' }}
        </td>
    </tr>

    {# 🔹 Row for displaying Subject Teacher Comments (Only for Marksheet 1) #}
    {% if marksheet1.comment is defined and marksheet1.comment is not empty %}
    <tr>
        <td class="border-bottom border-left border-right bg-light text-sm" colspan="5" style="font-size: 8px; padding: 2px;">
            <i>{{ marksheet1.comment }}</i>
            <br>
            <span style="font-size: 7px; font-weight: bold; display: inline-block; width: 50%;">
                {{ marksheet1.teacherName is defined and marksheet1.teacherName is not empty 
                    ? marksheet1.teacherName 
                    : 'N/A' }}
            </span>
        </td>
    </tr>
    {% endif %}

    {% endfor %}
    
    {# ✅ Display Average Scores (If Configured) #}
    {% if config.includeAverage == 'Y' %}
    <tr>
        <td class="header bg-primary border-top border-bottom border-left border-right text-center" style="font-weight: bold;">
            {{ __('Average') }}
        </td>

        {# ✅ Compute Average for Marksheet 1 #}
        {% set total1 = 0 %}
        {% set count1 = 0 %}
        {% for course, assessments in internalAssessmentByCourse.courses %}
            {% set marksheet1 = assessments["Marksheet 1 -October 2025"] is defined ? assessments["Marksheet 1 -October 2025"] : {} %}
            {% if marksheet1.attainmentValue is defined and marksheet1.attainmentValue is not empty %}
                {% set total1 = total1 + (marksheet1.attainmentValue|replace({'%': ''})|trim)|default(0) %}
                {% set count1 = count1 + 1 %}
            {% endif %}
        {% endfor %}

        <td class="header bg-primary border-top border-bottom border-left border-right text-center">
            {{ count1 > 0 ? (total1 / count1)|round(1) ~ '%' : 'N/A' }}
        </td>

        <td class="header bg-primary border-top border-bottom border-left border-right text-center">
            N/A
        </td>

        {# ✅ Compute Average for Marksheet 2 (December Exam) #}
        {% set total2 = 0 %}
        {% set count2 = 0 %}
        {% for course, assessments in internalAssessmentByCourse.courses %}
            {% set marksheet2 = assessments["December Exam"] is defined ? assessments["December Exam"] : {} %}
            {% if marksheet2.attainmentValue is defined and marksheet2.attainmentValue is not empty %}
                {% set total2 = total2 + (marksheet2.attainmentValue|replace({'%': ''})|trim)|default(0) %}
                {% set count2 = count2 + 1 %}
            {% endif %}
        {% endfor %}

        <td class="header bg-primary border-top border-bottom border-left border-right text-center">
            {{ count2 > 0 ? (total2 / count2)|round(1) ~ '%' : 'N/A' }}
        </td>

        <td class="header bg-primary border-top border-bottom border-left border-right text-center">
            N/A
        </td>
    </tr>
    {% endif %}
</table>
